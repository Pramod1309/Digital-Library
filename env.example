# Database Configuration
DB_PASSWORD=your_secure_db_password

# Application Secrets
SECRET_KEY=your_secure_secret_key

# Email Configuration (if needed)
# EMAIL_HOST=smtp.your-email-provider.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@example.com
# EMAIL_PASSWORD=your-email-password
# DEFAULT_FROM_EMAIL=your-email@example.com
# DEFAULT_FROM_NAME=Your Company Name
# EMAIL_USE_TLS=true
# EMAIL_USE_SSL=false

# Brevo SMS Configuration for school OTP reset
# BREVO_SMS_API_KEY=your-brevo-sms-api-key
# BREVO_SMS_SENDER=Koshquest
# BREVO_SMS_DEFAULT_COUNTRY_CODE=91

# Frontend Environment Variables
REACT_APP_API_URL=/
NODE_ENV=production

# SSL Configuration (for Let's Encrypt)
# CERTBOT_EMAIL=your-email@example.com
# STAGING=1 # Set to 1 for testing, remove for production
